# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Inside Docker Compose, "mongodb" resolves via Docker's internal DNS.
MONGO_URI=mongodb://admin:secret@mongodb:27017/linkdb?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────────────────
# Inside Docker Compose, "redis" resolves via Docker's internal DNS.
REDIS_URL=redis://:redissecret@redis:6379
# Cache-Aside TTL: how long (seconds) a URL mapping lives in Redis before eviction.
# 86400 = 24 hours. Adjust per environment (e.g. lower in staging for faster iteration).
CACHE_TTL_SECONDS=86400

# ── Public base URL (used to construct the shortened link in API responses) ───
BASE_URL=http://localhost:5000

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
